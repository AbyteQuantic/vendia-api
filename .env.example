# ══════════════════════════════════════════════════════════════════════════════
# VendIA Backend — Variables de entorno
# Copia este archivo: cp .env.example .env  y completa los valores
# ══════════════════════════════════════════════════════════════════════════════

PORT=8080

# ── Environment ───────────────────────────────────────────────────────────────
# development | production
ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3099

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max login attempts per minute per IP
RATE_LIMIT_LOGIN=5

# ── Base de datos ─────────────────────────────────────────────────────────────
# Local development (via docker compose):
DATABASE_URL=postgres://vendia:vendia_secret@localhost:5499/vendia?sslmode=disable

# Production (Neon.tech):
# DATABASE_URL=postgres://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require

# ── Gemini (OCR + photo enhance + logo gen) ─────────────────────────────────
# Optional. If GEMINI_API_KEY is unset, the related endpoints return 503.
# GEMINI_API_KEY=AIza...
#
# Model overrides — leave empty to use the in-code defaults.
#   GEMINI_MODEL        → text/OCR. Default: gemini-2.0-flash
#   GEMINI_IMAGE_MODEL  → image edit/gen. Default: gemini-3-pro-image-preview
#                         (Nano Banana Pro — best identity preservation
#                         on product photos. Switch to
#                         gemini-3.1-flash-image-preview for cheaper /
#                         faster runs at the cost of fidelity.)
# GEMINI_MODEL=
# GEMINI_IMAGE_MODEL=

# ── ePayco (suscripción Pro — Feature 008) ──────────────────────────────────
# Pasarela de pagos para cobrar la suscripción Pro. Las cuatro llaves son
# opcionales en dev/test: sin ellas el checkout de suscripción responde 503
# y los tests mockean la pasarela (no se necesitan credenciales para
# `go test`). Se obtienen del panel de ePayco y se cargan en Render.
#
#   EPAYCO_PUBLIC_KEY   → llave pública del widget de checkout
#   EPAYCO_PRIVATE_KEY  → llave privada de servidor
#   EPAYCO_P_CUST_ID    → p_cust_id_cliente (id de cliente ePayco)
#   EPAYCO_P_KEY        → secreto para verificar la firma del webhook
#   EPAYCO_TEST_MODE    → true = sandbox, false = producción. Default: true
#                         (un valor inválido o ausente queda en sandbox).
# EPAYCO_PUBLIC_KEY=
# EPAYCO_PRIVATE_KEY=
# EPAYCO_P_CUST_ID=
# EPAYCO_P_KEY=
# EPAYCO_TEST_MODE=true
