# ══════════════════════════════════════════════════════════════════════════════
# VendIA Backend — Variables de entorno
# Copia este archivo: cp .env.example .env  y completa los valores
# ══════════════════════════════════════════════════════════════════════════════

PORT=8080

# ── Environment ───────────────────────────────────────────────────────────────
# development | production
ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3099

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max login attempts per minute per IP
RATE_LIMIT_LOGIN=5

# ── Base de datos ─────────────────────────────────────────────────────────────
# Local development (via docker compose):
DATABASE_URL=postgres://vendia:vendia_secret@localhost:5499/vendia?sslmode=disable

# Production (Neon.tech):
# DATABASE_URL=postgres://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require

# ── Gemini (OCR + photo enhance + logo gen) ─────────────────────────────────
# Optional. If GEMINI_API_KEY is unset, the related endpoints return 503.
# GEMINI_API_KEY=AIza...
#
# Model overrides — leave empty to use the in-code defaults.
#   GEMINI_MODEL        → text/OCR. Default: gemini-2.0-flash
#   GEMINI_IMAGE_MODEL  → image edit/gen. Default: gemini-3-pro-image-preview
#                         (Nano Banana Pro — best identity preservation
#                         on product photos. Switch to
#                         gemini-3.1-flash-image-preview for cheaper /
#                         faster runs at the cost of fidelity.)
# GEMINI_MODEL=
# GEMINI_IMAGE_MODEL=
